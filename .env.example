# ===== Supabase (必须) =====
# 从 Supabase Dashboard → Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# ===== AI (可选，缺失时 AI 解释功能不可用) =====
# DeepSeek API key
DEEPSEEK_API_KEY=

# ===== 支付 (Creem) =====
# 生产环境建议显式设置 CREEM_ENV=production
# 测试环境可设置 CREEM_ENV=test
# 上线前记得切换 live/production 密钥
CREEM_ENV=
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_STARTER_PRODUCT_ID=
CREEM_GROWTH_PRODUCT_ID=
CREEM_SCALE_PRODUCT_ID=
CREEM_STARTER_YEARLY_PRODUCT_ID=
CREEM_GROWTH_YEARLY_PRODUCT_ID=
CREEM_SCALE_YEARLY_PRODUCT_ID=
CREEM_PRODUCT_STARTER_MONTHLY=
CREEM_PRODUCT_GROWTH_MONTHLY=
CREEM_PRODUCT_SCALE_MONTHLY=

# ===== Secwyn Premium V2 pricing cutover (server-only; safe default is false) =====
SECWYN_PREMIUM_PRICING_V2_ENABLED=false
SECWYN_V2_ANNUAL_SELF_SERVE_ENABLED=false
CREEM_STARTER_MONTHLY_V2_PRODUCT_ID=
CREEM_GROWTH_MONTHLY_V2_PRODUCT_ID=
CREEM_SCALE_MONTHLY_V2_PRODUCT_ID=
CREEM_STARTER_ANNUAL_V2_PRODUCT_ID=
CREEM_GROWTH_ANNUAL_V2_PRODUCT_ID=
CREEM_SCALE_ANNUAL_V2_PRODUCT_ID=

# ===== 部署 =====
NEXT_PUBLIC_APP_URL=

# ===== Admin =====
# Comma-separated list of emails that can view the feedback inbox
ADMIN_EMAILS=

# ===== E8 outreach/revenue observability (all rollout flags default off) =====
OUTREACH_OBSERVABILITY_ENABLED=false
SES_EVENT_INGESTION_ENABLED=false
ACQUISITION_ATTRIBUTION_ENABLED=false
CREEM_ATTRIBUTION_METADATA_ENABLED=false
OUTREACH_SAFETY_AUTOPAUSE_ENABLED=false
OUTREACH_DASHBOARD_ENABLED=false
# Safe default is true when omitted. Set false only during an approved rollout.
OUTREACH_GLOBAL_KILL_SWITCH=true

# Server-only E8 secrets. Use independent random values of at least 32 characters.
E8_CID_HMAC_KEY=
E8_CID_HMAC_PREVIOUS_KEY=
E8_IDENTITY_HMAC_KEY=
E8_ANON_HMAC_KEY=

# AWS SES/SNS ingestion allowlist. Comma-separate exact SNS Topic ARNs.
AWS_REGION=
AWS_SES_CONFIGURATION_SET=
AWS_SNS_ALLOWED_TOPIC_ARNS=

# Internal safety thresholds: 2% hard bounce; 0.05% complaint per delivery.
E8_HARD_BOUNCE_PAUSE_RATE=0.02
E8_COMPLAINT_PAUSE_RATE=0.0005
